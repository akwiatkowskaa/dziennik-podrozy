@model Trip
@{
    ViewData["Title"] = "Edycja podróży";
}
<h2>Edytuj podróż</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-2">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="DateFrom"></label>
        <input asp-for="DateFrom" type="date" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="DateTo"></label>
        <input asp-for="DateTo" type="date" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="mb-2">
        <label asp-for="CountryId">Kraj</label>
        <select asp-for="CountryId" asp-items="ViewBag.CountryId" class="form-select"></select>
    </div>
    <div class="mb-2">
        <label asp-for="UserId">Użytkownik</label>
        <select asp-for="UserId" asp-items="ViewBag.UserId" class="form-select"></select>
    </div>
    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
</form>
