@model Trip
@{
    ViewData["Title"] = "Edycja podróży";
    var isAdmin = ViewBag.IsAdmin as bool? == true;
}
<div class="page-header">
    <h2>Edytuj podróż</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Wróć do listy</a>
</div>

<div class="card shadow-sm form-card">
    <div class="card-body">
        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

        <form asp-controller="Trips" asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Tytuł podróży</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Data od</label>
                    <input asp-for="DateFrom" type="date" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Data do</label>
                    <input asp-for="DateTo" type="date" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Opis <span class="text-muted">(opcjonalnie)</span></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Kraj</label>
                    <select asp-for="CountryId" asp-items="ViewBag.CountryId" class="form-select"></select>
                </div>
                @if (isAdmin)
                {
                    <div class="col-md-6">
                        <label class="form-label">Właściciel</label>
                        <select asp-for="UserId" asp-items="ViewBag.UserId" class="form-select"></select>
                    </div>
                }
                else
                {
                    <input type="hidden" asp-for="UserId" />
                }
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Zapisz zmiany</button>
                <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
            </div>
        </form>
    </div>
</div>
