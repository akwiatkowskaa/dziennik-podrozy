@model DziennikPodrozy.Models.ViewModels.ExpenseReportViewModel
@{
    ViewData["Title"] = "Raport wydatków";
}
<h2>Raport wydatków</h2>
<p class="text-muted">Wybierz podróż — zobaczysz, na co wydałaś pieniądze w tej wyprawie.</p>

@if (Model.Trips.Count == 0)
{
    <p class="alert alert-warning">Nie masz podróży — dodaj podróż, potem wydatki.</p>
}
else
{
    <form method="get" class="row g-2 align-items-end mb-4">
        <div class="col-auto">
            <label class="form-label">Podróż</label>
            <select name="tripId" class="form-select" onchange="this.form.submit()">
                @foreach (var t in Model.Trips)
                {
                    if (Model.SelectedTripId == t.Id)
                    {
                        <option value="@t.Id" selected="selected">@t.Title</option>
                    }
                    else
                    {
                        <option value="@t.Id">@t.Title</option>
                    }
                }
            </select>
        </div>
    </form>

    @if (Model.SelectedTripId.HasValue)
    {
        <h4>@Model.SelectedTripTitle</h4>
        <p>Łącznie w tej podróży: <strong>@Model.Total.ToString("0.00") zł</strong></p>

        @if (Model.Categories.Count == 0)
        {
            <p class="text-muted">Brak wydatków dla tej podróży.</p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr><th>Kategoria</th><th>Kwota</th><th>% całości</th></tr>
                </thead>
                <tbody>
                @foreach (var c in Model.Categories)
                {
                    <tr>
                        <td>@c.Category</td>
                        <td>@c.Sum.ToString("0.00") zł</td>
                        <td>@c.Percent%</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    }
}
