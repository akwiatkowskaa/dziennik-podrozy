@model Expense
@{
    ViewData["Title"] = "Edycja wydatku";
}
<h2>Edytuj wydatek</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-2">
        <label asp-for="TripId">Podróż</label>
        <select asp-for="TripId" asp-items="ViewBag.TripId" class="form-select"></select>
    </div>
    <div class="mb-2">
        <label asp-for="ExpenseDate"></label>
        <input asp-for="ExpenseDate" type="date" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Amount"></label>
        <input asp-for="Amount" class="form-control" step="0.01" />
    </div>
    <div class="mb-2">
        <label asp-for="Category"></label>
        <input asp-for="Category" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Description"></label>
        <input asp-for="Description" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
</form>
