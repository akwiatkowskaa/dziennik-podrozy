@model Expense
@{
    ViewData["Title"] = "Edycja wydatku";
}
<h2>Edytuj wydatek</h2>
<form asp-controller="Expenses" asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-2">
        <label class="form-label">Podróż</label>
        <select asp-for="TripId" asp-items="ViewBag.TripId" class="form-select"></select>
    </div>
    <div class="mb-2">
        <label class="form-label">Data</label>
        <input asp-for="ExpenseDate" type="date" class="form-control" />
    </div>
    <div class="mb-2">
        <label class="form-label">Kwota (zł)</label>
        <input asp-for="Amount" class="form-control" step="0.01" />
    </div>
    <div class="mb-2">
        <label class="form-label">Kategoria</label>
        <input asp-for="Category" class="form-control" />
    </div>
    <div class="mb-2">
        <label class="form-label">Opis <span class="text-muted">(opcjonalnie)</span></label>
        <input asp-for="Description" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
</form>
