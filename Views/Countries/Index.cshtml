@model IEnumerable<Country>
@{
    ViewData["Title"] = "Kraje";
}
<h2>Kraje</h2>
<p><a asp-action="Create" class="btn btn-primary btn-sm">Dodaj kraj</a></p>
<table class="table table-striped">
    <thead>
        <tr><th>Id</th><th>Nazwa</th><th>Kod</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Code</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edytuj</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Usuń</a>
            </td>
        </tr>
    }
    </tbody>
</table>
