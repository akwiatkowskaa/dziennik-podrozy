@model JournalEntry
@{
    ViewData["Title"] = "Edycja wpisu";
}
<h2>Edytuj wpis</h2>
<form asp-controller="JournalEntries" asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-2">
        <label class="form-label">Podróż</label>
        <select asp-for="TripId" asp-items="ViewBag.TripId" class="form-select"></select>
    </div>
    <div class="mb-2">
        <label class="form-label">Data</label>
        <input asp-for="EntryDate" type="date" class="form-control" />
    </div>
    <div class="mb-2">
        <label class="form-label">Tytuł</label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="mb-2">
        <label class="form-label">Opis <span class="text-muted">(opcjonalnie)</span></label>
        <textarea asp-for="Content" class="form-control" rows="4"></textarea>
    </div>
    <div class="mb-2">
        <label class="form-label">Ocena miejsca (1–5)</label>
        <input asp-for="Rating" type="number" min="1" max="5" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
</form>
