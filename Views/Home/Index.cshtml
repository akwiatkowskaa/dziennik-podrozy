@{
    ViewData["Title"] = "Start";
}
<h2>Witaj, @Context.Session.GetString("User")!</h2>
<p class="text-muted">Krótkie podsumowanie danych w bazie (później tu będzie pełny dashboard).</p>

<div class="row mt-4">
    <div class="col-md-3">
        <div class="card"><div class="card-body">
            <h5>Podróże</h5>
            <p class="display-6">@ViewBag.TripCount</p>
        </div></div>
    </div>
    <div class="col-md-3">
        <div class="card"><div class="card-body">
            <h5>Kraje</h5>
            <p class="display-6">@ViewBag.CountryCount</p>
        </div></div>
    </div>
    <div class="col-md-3">
        <div class="card"><div class="card-body">
            <h5>Wpisy</h5>
            <p class="display-6">@ViewBag.EntryCount</p>
        </div></div>
    </div>
    <div class="col-md-3">
        <div class="card"><div class="card-body">
            <h5>Suma wydatków</h5>
            <p class="display-6">@(((decimal)ViewBag.ExpenseSum).ToString("0.00")) zł</p>
        </div></div>
    </div>
</div>
<p class="mt-3">Średnia ocena wpisów: <strong>@(((double)ViewBag.AvgRating).ToString("0.0"))</strong> / 5</p>

<h4 class="mt-4">Przejdź do tabel</h4>
<ul>
    <li><a asp-controller="Countries" asp-action="Index">Kraje</a></li>
    <li><a asp-controller="Trips" asp-action="Index">Podróże</a></li>
    <li><a asp-controller="JournalEntries" asp-action="Index">Wpisy dziennika</a></li>
    <li><a asp-controller="Expenses" asp-action="Index">Wydatki</a></li>
</ul>
